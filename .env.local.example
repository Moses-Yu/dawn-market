# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (used by the AI summarization pipeline)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Pipeline API key (protects /api/pipeline/*, /api/research/*, /api/push/send, /api/admin/*)
PIPELINE_API_KEY=your-pipeline-api-key

# Vercel Cron secret (protects /api/cron/*, /api/health/pipeline, /api/health/errors GET)
CRON_SECRET=your-cron-secret

# Toss Payments (subscription billing)
TOSS_SECRET_KEY=your-toss-secret-key

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@dawn-market.kr

# Public site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
